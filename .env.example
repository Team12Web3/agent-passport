# Required: thirdweb Client ID for /auth ConnectEmbed + wallet-backed txs.
# This is the public, browser-safe Client ID from https://thirdweb.com/dashboard.
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=aa888f4f69bfe6353cdf02ae70f8047c

# Optional: pin a deployed AgentPassport contract on Avalanche Fuji.
# If unset, the dashboard's one-click "Deploy contract" button will mint a fresh
# contract from your wallet and remember the address in localStorage.
# NEXT_PUBLIC_AGENT_PASSPORT_ADDRESS=0xYourDeployedContractAddress
