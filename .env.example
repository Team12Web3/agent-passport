# Avalanche Fuji C-Chain
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
FUJI_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Deployed contract from `pnpm contracts:deploy:fuji`
AGENT_PASSPORT_CONTRACT=0xYourDeployedContract

# Agent wallet/private key used by apps/agent-demo
AGENT_PRIVATE_KEY=0xYOUR_AGENT_WALLET_PRIVATE_KEY
AGENT_PASSPORT_ID=1

# Target site
NEXT_PUBLIC_TARGET_DOMAIN=localhost:3001
NEXT_PUBLIC_CHAIN_ID=43113
