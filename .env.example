# ============================================================
# Public (exposed to browser) - all must be prefixed NEXT_PUBLIC_
# ============================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Thirdweb (auth + embedded wallets)
NEXT_PUBLIC_TW_CLIENT_ID=
NEXT_PUBLIC_THIRDWEB_AUTH_DOMAIN=localhost:3000

# Avalanche Fuji testnet
NEXT_PUBLIC_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_FUJI_CHAIN_ID=43113

# Deployed contract addresses (filled in by Person 1 after deploy)
NEXT_PUBLIC_PASSPORT_ADDRESS=
NEXT_PUBLIC_ACTIONLOG_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65   # Fuji testnet USDC

# ============================================================
# Server-only secrets - NEVER prefix with NEXT_PUBLIC_
# ============================================================

# LLM
ANTHROPIC_API_KEY=

# Web scraping
FIRECRAWL_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Thirdweb server-side auth
THIRDWEB_SECRET_KEY=
AUTH_PRIVATE_KEY=0x

# Encryption key for agent wallet private keys
# Generate: openssl rand -hex 32
AGENT_KEY_SECRET=

# Faucet wallet — funds new agent wallets with AVAX + USDC
# This wallet must hold test AVAX and test USDC on Fuji.
FAUCET_PRIVATE_KEY=

# Platform wallet — pays gas to mint passports on behalf of users
# (Same as faucet for hackathon; can be the same key.)
PLATFORM_PRIVATE_KEY=

# Optional staking defaults for the StakeVault companion contract
AGENT_REQUIRED_STAKE_ETH=0.1
AGENT_SLASH_AMOUNT_ETH=0.1
