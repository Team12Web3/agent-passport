{
   "action": {
      "default_icon": "icons/icon128x128.png",
      "default_popup": "src/popup.html"
   },
   "background": {
      "service_worker": "javascript/background.js",
      "type": "module"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "javascript/content.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_end"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'"
   },
   "default_locale": "en",
   "description": "__MSG_desc__",
   "icons": {
      "128": "icons/icon128x128.png",
      "32": "icons/icon32x32.png",
      "48": "icons/icon48x48.png",
      "64": "icons/icon64x64.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_name__",
   "options_ui": {
      "open_in_tab": true,
      "page": "src/index.html?page=settings&tab=blockList"
   },
   "permissions": [ "storage", "activeTab", "tabs", "alarms" ],
   "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx",
   "version": "1.0.4"
}
