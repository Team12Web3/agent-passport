{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local", "tsconfig.json"],
  "globalEnv": ["NODE_ENV", "VERCEL_ENV"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": ["**/*.tsbuildinfo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "NEXT_PUBLIC_*",
        "ANTHROPIC_API_KEY",
        "FIRECRAWL_API_KEY",
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_DB_URL",
        "AGENT_KEY_SECRET",
        "FAUCET_PRIVATE_KEY",
        "PLATFORM_PRIVATE_KEY",
        "THIRDWEB_SECRET_KEY",
        "OPENAI_API_KEY",
        "PLATFORM_ADDRESS",
        "USDC_ADDRESS",
        "SNOWTRACE_API_KEY",
        "AUTH_PRIVATE_KEY"
      ]
    }
  }
}
