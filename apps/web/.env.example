# --- Public (Vercel: plain) -------------------------------------------------
NEXT_PUBLIC_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_TW_CLIENT_ID=

NEXT_PUBLIC_USDC_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
NEXT_PUBLIC_THIRDWEB_AUTH_DOMAIN=localhost:3000


# Legacy alias also accepted (lib/thirdwebClient.ts checks both).
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
NEXT_PUBLIC_USDC_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
NEXT_PUBLIC_THIRDWEB_AUTH_DOMAIN=localhost:3000

# Optional: pin the dashboard at /dashboard to a legacy AgentPassport
# deployment (string-keyed `getPassport(string agentId)` ABI). When unset,
# the dashboard renders mock data so the UI still demos cleanly.
NEXT_PUBLIC_AGENT_PASSPORT_ADDRESS=

# --- Server-only (Vercel: sensitive) ----------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
THIRDWEB_SECRET_KEY=
AUTH_PRIVATE_KEY=0x

OPENAI_API_KEY=
# Optional model overrides (defaults: gpt-4o-mini for cheap, gpt-5-mini for complex)
OPENAI_MODEL_CHEAP=
OPENAI_MODEL_COMPLEX=

FIRECRAWL_API_KEY=

# Platform/faucet wallet — mints passports, funds new agents
PLATFORM_PRIVATE_KEY=0x
PLATFORM_ADDRESS=0x
FAUCET_PRIVATE_KEY=0x

# Generated via `openssl rand -hex 32` — used by lib/agent/wallet.ts to
# encrypt agent EOAs before storing in Supabase.
AGENT_KEY_SECRET=

# Optional staking defaults for the StakeVault companion contract
AGENT_REQUIRED_STAKE_ETH=0.1
AGENT_SLASH_AMOUNT_ETH=0.1

# Optional: snowtrace verification
SNOWTRACE_API_KEY=
